# ─────────────────────────────────────────────────────────────────────────────
# Box Challenge — variables de entorno (copia a .env.local y rellena valores)
# ─────────────────────────────────────────────────────────────────────────────
# Prisma carga primero .env.local y luego .env (ver prisma.config.ts).
# En Next.js, usa .env.local para desarrollo (no lo subas a git).

# ─── App pública ─────────────────────────────────────────────────────────────

# URL canónica de la app (enlaces de invitación, emails, logo en correos).
# En local: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Si la app vive bajo un subpath (ej. /retos), descomenta:
# NEXT_PUBLIC_BASE_PATH=/retos

# ─── Base de datos (PostgreSQL / Supabase) ───────────────────────────────────

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?schema=public

# Conexiones máximas del pool (opcional; default 4)
# DATABASE_POOL_MAX=4

# ─── Autenticación (NextAuth v5) ─────────────────────────────────────────────

# Secreto para firmar sesiones JWT, cookies MFA y cifrado del secreto TOTP.
# Genera uno: openssl rand -base64 32
AUTH_SECRET=

# Alias legacy (opcional si ya lo usabas)
# NEXTAUTH_SECRET=

# URL interna de NextAuth (local)
NEXTAUTH_URL=http://localhost:3000

# ─── Google OAuth (opcional) ───────────────────────────────────────────────────

# Crea credenciales en Google Cloud Console → OAuth 2.0
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=

# Muestra el botón "Continuar con Google" en login/registro
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=false

# ─── Correo — verificación de email (SMTP gratis) ────────────────────────────
#
# MFA (códigos TOTP) NO usa correo ni APIs de pago — es 100 % local (otplib).
# Solo el registro con email/contraseña envía un correo de confirmación.
#
# Desarrollo sin SMTP: el enlace de verificación aparece en la consola del servidor.
#
# ── Opción A: Gmail (contraseña de aplicación) ──
# EMAIL_FROM="Box Challenge <tu@gmail.com>"
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu@gmail.com
# SMTP_PASS=xxxx-xxxx-xxxx-xxxx
#
# ── Opción B: Brevo SMTP (~300 emails/día gratis) ──
# Requiere autorizar IP en Brevo si falla con "Unauthorized IP address"
# EMAIL_FROM="Box Challenge <noreply@tudominio.com>"
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=tu-login-brevo
# SMTP_PASS=xsmtpsib-...
#
# ── Opción C: Brevo API HTTP (recomendado; sin whitelist IP SMTP) ──
# Brevo → Settings → SMTP & API → Create API key (empieza por xkeysib-)
# BREVO_API_KEY=xkeysib-...
# EMAIL_FROM="Box Challenge <email-verificado-en-brevo@dominio.com>"
#
# Puerto 465 con SSL:
# SMTP_SECURE=true

EMAIL_FROM="Box Challenge <noreply@example.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Brevo API (recomendado — evita error "Unauthorized IP" del SMTP)
# BREVO_API_KEY=

# ─── Supabase (storage de imágenes / media) ──────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─── Cron / tareas programadas (opcional) ────────────────────────────────────

# CRON_SECRET=

# ─── Notas ───────────────────────────────────────────────────────────────────
#
# Producción (Vercel): define las mismas variables en el dashboard del proyecto.
# VERCEL_PROJECT_PRODUCTION_URL la inyecta Vercel automáticamente.
#
# Migraciones: npx prisma migrate deploy
# Desarrollo:   npm run dev
